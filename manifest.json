{
    "manifest_version": 3,
    "name": "Arquivos de Portugal",
    "version": "2.0.0",
    "description": "Descarga masiva de ArquivosPT (Digitarq)",
    "permissions": [
      "activeTab",
      "downloads"
    ],
    "host_permissions": [
      "*://*.arquivos.pt/*"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "img/icon16.png",
        "48": "img/icon48.png",
        "128": "img/icon128.png"
      }
    },
    "icons": {
      "16": "img/icon16.png",
      "48": "img/icon48.png",
      "128": "img/icon128.png"
    }
  }
